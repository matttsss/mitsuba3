    %v2 = bitcast <8 x float> %v0_0_2 to <8 x float>
    %v3 = bitcast <8 x float> %v0_0_3 to <8 x float>
    %v4 = bitcast <8 x float> %v0_0_4 to <8 x float>
    %v5 = bitcast <8 x float> %v0_0_5 to <8 x float>
    %v6 = bitcast <8 x float> %v0_0_6 to <8 x float>
